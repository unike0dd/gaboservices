     return `${sourceUrl.pathname}${sourceUrl.search}${sourceUrl.hash}`;
   }
 
+  function resolveControlTarget(control, targetLang) {
+    const explicitTarget = control.getAttribute('data-lang-href') || control.getAttribute('href');
+    if (explicitTarget) {
+      try {
+        const explicitUrl = new URL(explicitTarget, window.location.origin);
+        if (explicitUrl.origin === window.location.origin) {
+          return `${explicitUrl.pathname}${explicitUrl.search}${explicitUrl.hash}`;
+        }
+        return explicitUrl.toString();
+      } catch {
+        // Fall back to computed locale path below.
+      }
+    }
+
+    return toLocalizedPath(targetLang);
+  }
+
   window.GaboLanguageSwitcher = {
     initLanguageSwitcher({ supported = SUPPORTED, defaultLang = 'en', onChange } = {}) {
       const activeSupported = supported.filter((lang) => SUPPORTED.includes(lang));
@@ -60,12 +77,13 @@
         document.querySelectorAll('[data-lang-option]').forEach((control) => {
           if ('disabled' in control) control.disabled = false;
           control.addEventListener('click', (event) => {
-            if (control.tagName === 'A') event.preventDefault();
             const nextLang = normalizeLang(control.getAttribute('data-lang-option'));
+            const target = resolveControlTarget(control, nextLang);
+            if (control.tagName === 'A') event.preventDefault();
             if (!activeSupported.includes(nextLang) || nextLang === current) return;
             current = nextLang;
             notify();
-            window.location.assign(toLocalizedPath(current));
+            window.location.assign(target);
           });
         });
       };
