  "pageStructureRules": [
    {
      "appliesTo": [
        "index.html",
        "es/index.html"
      ],
      "checks": {
        "exactlyOneH1": true,
        "requireHeroButtons": true,
        "requireHeroSupportingLine": true
      }
    },
    {
      "appliesTo": [
        "about/index.html",
        "es/about/index.html",
        "services/index.html",
        "es/services/index.html",
        "services/logistics-operations/index.html",
        "es/services/logistics-operations/index.html",
        "services/administrative-backoffice/index.html",
        "es/services/administrative-backoffice/index.html",
        "services/customer-relations/index.html",
        "es/services/customer-relations/index.html",
        "services/it-support/index.html",
        "es/services/it-support/index.html",
        "pricing/index.html",
        "es/pricing/index.html",
        "contact/index.html",
        "es/contact/index.html",
        "learning/index.html",
        "es/learning/index.html",
        "legal/terms.html",
        "legal/cookies.html",
        "legal/privacy-gdpr.html",
        "es/legal/terms.html",
        "es/legal/cookies.html",
        "es/legal/privacy-gdpr.html"
      ],
      "checks": {
        "exactlyOneH1": true,
        "requireAtLeastOneH2": true
      }
    },
    {
      "appliesTo": [
        "careers/index.html",
        "es/careers/index.html"
      ],
      "checks": {
        "exactlyOneH1": true,
        "forbidTopLevelH2AsPageTitle": true,
        "requireFormLabels": true
      }
    }
  ],
  "pairRules": [
    {
      "type": "routeParity",
      "requireEquivalentFilesForEachLocale": true
    },
    {
      "type": "switcherParity",
      "requireEnglishPageToPointToSpanishEquivalent": true,
      "requireSpanishPageToPointToEnglishEquivalent": true
    },
    {
      "type": "internalLinkParity",
      "requireEnglishInternalLinksToStayEnglish": true,
      "requireSpanishInternalLinksToStaySpanish": true
    },
    {
      "type": "headingParity",
      "checkSameHeadingLevelStructureAcrossLocales": true
    },
    {
      "type": "formParity",
      "checkEquivalentFieldsAcrossLocales": true
    },
    {
      "type": "buttonParity",
      "checkEquivalentPrimaryActionsAcrossLocales": true
    }
  ],
  "switchingRules": {
    "persistSelectedLocale": true,
    "allowManualLocaleOverride": true,
    "forbidAutoResetToDefaultLocaleAfterManualSwitch": true,
    "forbidMixedPartialInjection": true,
    "forbidSharedNavWithoutLocaleMapping": true,
    "forbidSharedFooterWithoutLocaleMapping": true,
    "forbidFallbackToWrongLocaleWhenTranslationKeyMissing": true,
    "requireEquivalentSwitcherHref": true,
    "requireLocaleAwareCanonical": true,
    "requireLocaleAwareInternalHrefRendering": true
  },
  "fileOverrides": [
    {
      "file": "services/index.html",
      "forbiddenPhrases": [
        "Service matrix",
        "A scan-friendly view of how each service line supports execution priorities.",
        "Engagement options",
        "On-demand",
        "Ongoing coverage",
        "How we support execution"
      ]
    },
    {
      "file": "es/services/index.html",
      "forbiddenPhrases": [
        "Service matrix",
        "A scan-friendly view of how each service line supports execution priorities.",
        "Engagement options",
        "On-demand",
        "Ongoing coverage",
        "How we support execution"
      ]
    }
  ],
  "repoCoverage": {
    "checkSourceFiles": true,
    "checkSharedPartials": true,
    "checkLayouts": true,
    "checkLocaleDictionaries": true,
    "checkLanguageSwitcherScripts": true,
    "checkTemplateInjectedLinks": true
  },
  "liveSiteCoverage": {
    "checkRenderedPages": true,
    "checkRenderedNav": true,
    "checkRenderedFooter": true,
    "checkRenderedButtons": true,
    "checkRenderedForms": true,
    "checkRenderedInternalLinks": true,
    "checkSwitcherTargets": true,
    "checkLocalePersistenceAfterReload": true,
    "checkLocalePersistenceAfterNavigation": true
  },
  "recommendedDiagnostics": {
    "reportMissingLocalePairs": true,
    "reportWrongHtmlLang": true,
    "reportMixedLanguageNav": true,
    "reportMixedLanguageFooter": true,
    "reportMixedButtons": true,
    "reportMixedFormLabels": true,
    "reportCrossLocaleInternalLinks": true,
    "reportMissingSwitcherLink": true,
    "reportWrongSwitcherTarget": true,
    "reportMissingCanonical": true,
    "reportMissingHreflang": true,
    "reportHeadingHierarchyIssues": true,
    "reportMissingFormParity": true,
    "reportLocalePersistenceFailure": true,
    "reportStoredLocaleIgnored": true
  }
