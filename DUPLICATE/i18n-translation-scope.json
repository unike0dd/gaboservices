    "requireAlternateHreflangLinks": true,
    "requireCanonicalPerLocale": true,
    "requireLanguageSwitcherLinksToEquivalentRoute": true,
    "requireOneActiveLocalePerPage": true,
    "requireLocaleConsistentInternalLinks": true,
    "requireLocalePersistentSelection": true,
    "forbidMixedNav": true,
    "forbidMixedFooter": true,
    "forbidCrossLocaleButtons": true,
    "forbidCrossLocaleHeadings": true,
    "forbidCrossLocaleFormLabels": true,
    "forbidCrossLocaleInternalLinks": true,
    "forbidCrossLocaleLegalUi": true,
    "forbidMixedPartialInjection": true,
    "forbidSharedNavWithoutLocaleMapping": true,
    "forbidSharedFooterWithoutLocaleMapping": true,
    "forbidFallbackToWrongLocaleWhenTranslationKeyMissing": true,
    "forbidSilentFallbackToWrongLocale": true
