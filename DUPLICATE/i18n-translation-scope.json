      "esUrl": "/es/services/it-support/",
      "enFile": "services/it-support/index.html",
      "esFile": "es/services/it-support/index.html"
    },
    {
      "name": "pricing",
      "enUrl": "/pricing/",
      "esUrl": "/es/pricing/",
      "enFile": "pricing/index.html",
      "esFile": "es/pricing/index.html"
    },
    {
      "name": "careers",
      "enUrl": "/careers/",
      "esUrl": "/es/careers/",
      "enFile": "careers/index.html",
      "esFile": "es/careers/index.html"
    },
    {
      "name": "contact",
      "enUrl": "/contact/",
      "esUrl": "/es/contact/",
      "enFile": "contact/index.html",
      "esFile": "es/contact/index.html"
    },
    {
      "name": "learning",
      "enUrl": "/learning/",
      "esUrl": "/es/learning/",
      "enFile": "learning/index.html",
      "esFile": "es/learning/index.html"
    },
    {
      "name": "legal-terms",
      "enUrl": "/legal/terms.html",
      "esUrl": "/es/legal/terms.html",
      "enFile": "legal/terms.html",
      "esFile": "es/legal/terms.html"
    },
    {
      "name": "legal-cookies",
      "enUrl": "/legal/cookies.html",
      "esUrl": "/es/legal/cookies.html",
      "enFile": "legal/cookies.html",
      "esFile": "es/legal/cookies.html"
    },
    {
      "name": "legal-privacy-gdpr",
      "enUrl": "/legal/privacy-gdpr.html",
      "esUrl": "/es/legal/privacy-gdpr.html",
      "enFile": "legal/privacy-gdpr.html",
      "esFile": "es/legal/privacy-gdpr.html"
    }
  ],
  "missingPairPolicy": {
    "createMissingEquivalentPage": true,
    "createMissingEquivalentLinkTargets": true,
    "failValidationIfPairMissingAfterBuild": true
  },
