{
  "site": "gabriel.services",
  "version": "3.0.0",
  "policyType": "whole-site-universal-locale-policy",
  "description": "Universal EN/ES locale policy for route pairing, internal-link correctness, persisted user selection, mixed-language prevention, and whole-site validation.",
  "locales": [
    "en",
    "es"
  ],
  "defaultLocale": "en",
  "pathStrategy": {
    "en": "",
    "es": "es/"
  },
  "brandPolicy": {
    "requiredBrandName": "Gabriel Services",
    "preferredITLabel": {
      "en": "IT",
      "es": "TI"
    }
  },
  "storagePolicy": {
    "enabled": true,
    "persistAcrossSessions": true,
    "driver": "localStorage",
    "key": "gabrielServices.locale",
    "cookieFallback": {
      "enabled": true,
      "name": "gabrielServices.locale",
      "maxAgeDays": 365,
      "sameSite": "Lax",
      "path": "/"
    },
    "manualSelectionWins": true,
    "forbidAutoResetToDefaultAfterManualSelection": true,
    "resolutionOrder": [
      "urlPathLocale",
      "storedLocale",
      "documentLang",
      "defaultLocale"
    ]
  },
  "switcherBehavior": {
    "enabled": true,
    "controls": [
      {
        "label": "EN",
        "targetLocale": "en"
      },
      {
        "label": "ES",
        "targetLocale": "es"
      }
    ],
    "clickRules": {
      "enClickMustOpenEnglishEquivalent": true,
      "esClickMustOpenSpanishEquivalent": true,
      "setStoredLocaleOnManualClick": true,
      "setCookieFallbackOnManualClick": true,
      "navigateToEquivalentRouteOnManualClick": true,
      "preserveQueryString": true,
      "preserveHash": true,
      "updateHtmlLang": true,
      "updateCanonical": true,
      "updateAlternateHreflangLinks": true
    }
  },
  "internalLinkPolicy": {
    "enabled": true,
    "requireLocaleConsistentInternalLinks": true,
    "englishPagesMustLinkToEnglishInternalRoutesOnly": true,
    "spanishPagesMustLinkToSpanishInternalRoutesOnly": true,
    "externalLinksExcludedFromLocaleRewrite": true,
    "requireLocaleAwareNav": true,
    "requireLocaleAwareFooter": true,
    "requireLocaleAwareButtons": true,
    "requireLocaleAwareFormActions": true,
    "forbidCrossLocaleInternalHrefs": true
  },
  "routePairs": [
    {
      "name": "home",
      "enUrl": "/",
      "esUrl": "/es/",
      "enFile": "index.html",
      "esFile": "es/index.html"
    },
    {
      "name": "about",
      "enUrl": "/about/",
      "esUrl": "/es/about/",
      "enFile": "about/index.html",
      "esFile": "es/about/index.html"
    },
    {
      "name": "services",
      "enUrl": "/services/",
      "esUrl": "/es/services/",
      "enFile": "services/index.html",
      "esFile": "es/services/index.html"
    },
    {
      "name": "services-logistics-operations",
      "enUrl": "/services/logistics-operations/",
      "esUrl": "/es/services/logistics-operations/",
      "enFile": "services/logistics-operations/index.html",
      "esFile": "es/services/logistics-operations/index.html"
    },
    {
      "name": "services-administrative-backoffice",
      "enUrl": "/services/administrative-backoffice/",
      "esUrl": "/es/services/administrative-backoffice/",
