name: Security Compliance

on:
  pull_request:
  push:
    branches:
      - main

permissions:
  contents: read

concurrency:
  group: security-compliance-${{ github.ref }}
  cancel-in-progress: true

jobs:
  secret-scan:
    name: Security + JS Syntax Guardrails
    runs-on: ubuntu-latest
    timeout-minutes: 20
    env:
      GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
      GITLEAKS_VERSION: 8.24.2
    steps:
      - name: Checkout repository without GitHub Actions marketplace dependencies
        run: |
          set -euo pipefail
          rm -rf .git
          git init .
          git config --global url."https://x-access-token:${GITHUB_TOKEN}@github.com/".insteadOf "https://github.com/"
          git remote add origin "https://github.com/${GITHUB_REPOSITORY}.git"
          if ! git fetch --no-tags --prune origin "${GITHUB_REF}"; then
            echo "Primary fetch failed for ${GITHUB_REF}."
            pr_number="${GITHUB_REF#refs/pull/}"
            pr_number="${pr_number%/merge}"

            if [[ "${GITHUB_REF}" == refs/pull/*/merge ]] && git fetch --no-tags --prune origin "refs/pull/${pr_number}/head"; then
              echo "Fetched refs/pull/${pr_number}/head as fallback for missing merge ref."
            elif git fetch --no-tags --prune origin "${GITHUB_SHA}"; then
              echo "Fetched commit SHA ${GITHUB_SHA} as fallback."
            else
              echo "Falling back to default branch fetch from origin/HEAD."
              git fetch --no-tags --prune origin +HEAD
            fi
          fi
          git checkout --detach "${GITHUB_SHA}" || git checkout --detach FETCH_HEAD

      - name: Install gitleaks binary
        run: |
          set -euo pipefail
          mkdir -p "$HOME/.local/bin"
          target="$HOME/.local/bin/gitleaks"
          if command -v gitleaks >/dev/null 2>&1 && gitleaks version | grep -q "version ${GITLEAKS_VERSION}"; then
            echo "Using preinstalled gitleaks ${GITLEAKS_VERSION}"
            install -m 0755 "$(command -v gitleaks)" "$target"
          else
            curl -sSL "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_linux_x64.tar.gz" -o /tmp/gitleaks.tar.gz
            tar -xzf /tmp/gitleaks.tar.gz -C /tmp gitleaks
            install -m 0755 /tmp/gitleaks "$target"
          fi
          echo "$HOME/.local/bin" >> "$GITHUB_PATH"

      - name: Guard workflow against invalid git depth usage
        run: |
          set -euo pipefail
          if grep -nE -- 'git fetch[^#]*--depth(=|[[:space:]]+)0([[:space:]]|$)' .github/workflows/*.yml; then
            echo "Invalid git fetch depth detected: --depth must be a positive number."
            exit 1
          fi


      - name: Validate i18n critical-vs-optional scope
        run: |
          set -euo pipefail
          node scripts/validate-i18n-scope.js --report reports/i18n-integrity-report.json

      - name: Validate chatbot policy parity map
        run: |
          set -euo pipefail
          node scripts/validate-chatbot-policy-parity.js

      - name: Run chatbot regression smoke checks
        run: |
          set -euo pipefail
          node scripts/chatbot-regression-smoke.js

      - name: Run JavaScript syntax checks
        run: |
          set -euo pipefail
          node scripts/check-js-syntax.mjs

      - name: Print i18n integrity report summary
        run: |
          set -euo pipefail
          cat reports/i18n-integrity-report.json

      - name: Verify locale generated artifacts are in sync
        run: |
          set -euo pipefail
          node scripts/check-locale-generated.js
      - name: Run gitleaks on pull request commit range
        if: github.event_name == 'pull_request'
        run: |
          set -euo pipefail
          git fetch --no-tags origin \
            "${{ github.event.pull_request.base.sha }}" \
            "${{ github.event.pull_request.head.sha }}"
          gitleaks git --no-banner --redact --exit-code 1 \
            --log-opts "${{ github.event.pull_request.base.sha }}..${{ github.event.pull_request.head.sha }}"

      - name: Run gitleaks on pull request checked-out tree
        if: github.event_name == 'pull_request'
        run: |
          set -euo pipefail
          gitleaks dir --no-banner --redact --exit-code 1 .

      - name: Run gitleaks on push history
        if: github.event_name != 'pull_request'
        run: |
          set -euo pipefail
          BEFORE_SHA="${{ github.event.before }}"
          AFTER_SHA="${{ github.sha }}"

          # Scan only the commits introduced by this push to keep CI latency low.
          # On brand-new branches/tags GitHub can provide an all-zero before SHA.
          if [[ "${BEFORE_SHA}" == "0000000000000000000000000000000000000000" ]]; then
            gitleaks git --no-banner --redact --exit-code 1 \
              --log-opts "-n 1 ${AFTER_SHA}"
          else
            gitleaks git --no-banner --redact --exit-code 1 \
              --log-opts "${BEFORE_SHA}..${AFTER_SHA}"
          fi
